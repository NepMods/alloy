APP_ENV=development                 # development | staging | production
APP_NAME=accounting_core
APP_PORT=8080
LOG_LEVEL=debug                     # debug | info | warn | error
LOG_FORMAT=text                     # text (dev) | json (prod)

DB_DRIVER=mysql
DB_DSN=root:testpass@tcp(localhost:3306)/test_alloy
DB_REPLICAS=                        
DB_POOL_MAX_OPEN=25
DB_POOL_MAX_IDLE=10
DB_POOL_CONN_MAX_LIFETIME=30m
DB_POOL_CONN_MAX_IDLE=15m

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

MESSAGING_BUS=redis
MESSAGING_ASYNC=true
MESSAGING_QUEUE_SIZE=1024
MESSAGING_WORKERS=4
MESSAGING_CHANNEL_PREFIX=accouunting