APP_ENV=development                 # development | staging | production
APP_NAME=accounting_core
APP_PORT=8080
LOG_LEVEL=debug                     # debug | info | warn | error
LOG_FORMAT=text                     # text (dev) | json (prod)

DB_DRIVER=pgx
DB_DSN=postgres:///accounting?sslmode=disable&host=/run/postgresql
DB_REPLICAS=                        
DB_POOL_MAX_OPEN=25
DB_POOL_MAX_IDLE=10
DB_POOL_CONN_MAX_LIFETIME=30m
DB_POOL_CONN_MAX_IDLE=15m